programa {
inclua biblioteca Matematica
  funcao inicio() {
    cadeia produto
    inteiro nascimento, ano, idade
  escreva("Qual seu ano de nascimento?")
leia(nascimento)
escreva("\nEstamos em que ano?")
leia(ano)

idade = ano - nascimento

se (idade >= 18)
      escreva("ACESSO LIBERADO")
senao
      escreva("ACESSO NEGADO")
      


  }
}